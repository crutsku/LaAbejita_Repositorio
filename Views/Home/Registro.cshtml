@model LaAbejita.Models.RegisterRequest

<div id="mensajeError" class="alert alert-danger alert-dismissible fade show alerta-flotante" role="alert" style="display:none;">
    <span id="textoError"></span>
    <button type="button" class="btn-close" onclick="document.getElementById('mensajeError').style.display='none'" aria-label="Close"></button>
</div>

<div class="container-fluid registro-page">
    
    <div class="row justify-content-center">
        <div class="col-md-4">
            <h3 class="fw-bold mb-3">Registra tu cuenta</h3>

            <div class="d-flex justify-content-center mb-4">
                <p class="registro-subtitle mb-0">
                    ¿Ya comenzaste con tu registro?
                    <span class="registro-click" onclick="location.href='@Url.Action("Login", "Home")'">Click</span>
                </p>
            </div>


            <div class="mb-2">
                <input type="text" id="nombre" class="form-control" placeholder="Nombre">
            </div>

            <div class="mb-2">
                <input type="text" id="apellidoPaterno" class="form-control" placeholder="Apellido paterno">
            </div>

            <div class="mb-2">
                <input type="text" id="apellidoMaterno" class="form-control" placeholder="Apellido materno">
            </div>

            <div class="mb-2">
                <input type="text" id="username" class="form-control" placeholder="Nombre de usuario">
            </div>

            <div class="row mb-2">
                <div class="col-md-6 mb-2 mb-md-0">
                    <select id="rol" class="form-control">
                        <option value="">Selecciona un rol</option>
                        <option value="1">Administrador</option>
                        <option value="2">Cocinero</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <input type="text" id="numeroCelular" class="form-control" placeholder="Tu móvil">
                </div>
            </div>

            <div class="mb-3">
                <input type="password" id="contrasena" class="form-control" placeholder="Crea una contraseña">
            </div>

            <button class="btn btn-warning w-100" onclick="registrarUsuario()">
                Registrar cuenta
            </button>

            <p class="forgot-password mt-2 text-center">
                ¿Olvidaste tu contraseña?
            </p>

        </div>
    </div>
</div>

<script>
    function registrarUsuario() {

        var data = {
            nombre: document.getElementById("nombre").value,
            apellidoPaterno: document.getElementById("apellidoPaterno").value,
            apellidoMaterno: document.getElementById("apellidoMaterno").value,
            username: document.getElementById("username").value,
            rol: parseInt(document.getElementById("rol").value),
            numeroCelular: document.getElementById("numeroCelular").value,
            contrasena: document.getElementById("contrasena").value
        };

        fetch('/Home/Registro', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        })     

        .then(response => {
            if (!response.ok) {
              // Leemos el texto que enviamos desde C# (UsernameEnUso o TelefonoEnUso)
            return response.text().then(text => {
                if (text === "UsernameEnUso") {
                    throw new Error("El nombre de usuario está en uso");
                } else if (text === "TelefonoEnUso") {
                    throw new Error("El número celular está en uso");
                } else if(text === "CamposObligatorios"){

                    throw new Error("Se deben llenar los campos obligatorios");
                } else if(text === "LongitudErronea"){

                    throw new Error("El usuario y contraseña deben ser mayor a 5 carácteres");
                } else if(text === "NumeroErroneo"){

                    throw new Error("Ingresa un número de celular correcto");
                }
                else {
                    throw new Error("Error al registrar: " + text);
                }
            });
               
        }
        return response.text();
        })
        .then(result => {
            window.location.replace("/Home/Index");
        })
        .catch(error => {
        var cuadroError = document.getElementById("mensajeError");
        var texto = document.getElementById("textoError");

        texto.innerHTML = error.message;

        // Lo mostramos
        cuadroError.style.display = "block";
        });
        if (window.history.replaceState) {
        // Esto borra la página de registro del historial de navegación
        window.history.replaceState(null, null, window.location.href);
    }
    }

</script>